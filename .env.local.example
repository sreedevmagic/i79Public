# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Microsoft Clarity — Project ID (format: xxxxxxxxxx)
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# Resend API key — for contact form email sending (server-side only)
# Get yours at https://resend.com/api-keys
# NOTE: used only by the Azure Function in api/contact — NOT exposed to the browser
RESEND_API_KEY=re_xxxxxxxxxx

# Contact form recipient email — who receives the enquiry emails
# Defaults to sreedev.melethil@i79.ai if not set
CONTACT_EMAIL=sreedev.melethil@i79.ai
